// rabin_karp: Rabin-Karp 文字列検索 (rolling hash)
//
// pattern の hash と text の window hash を比較。 hash 一致したときだけ
// 文字単位で検証。 average O(N+M)、 worst O(NM)。
//
// hash: polynomial rolling hash h = c0 + c1*B + c2*B² + ... mod P
//
// 実行モード: interp + C + LLVM + Wasm の 4 backend で diff = 0

let base = 257;
let prime = 100003;   // C int32 で base * prime が溢れない範囲

// 文字列 s[i..i+len-1] の hash (initial computation、 後は rolling で更新)
let initial_hash = fn (s: str) -> fn (start: int) -> fn (sub_len: int) ->
  let rec go = fn i -> fn h ->
    if i >= sub_len then h
    else
      let c = ord (char_at s (start + i)) in
      go (i + 1) ((h * base + c) % prime) in
  go 0 0;

// 文字列等価判定 (hash 衝突時の確認用): s[si..si+len-1] == t[ti..ti+len-1]
let rec str_eq_range = fn (s: str) -> fn (si: int) ->
  fn (t: str) -> fn (ti: int) -> fn (sub_len: int) ->
  if sub_len <= 0 then true
  else if char_at s si != char_at t ti then false
  else str_eq_range s (si + 1) t (ti + 1) (sub_len - 1);

// base^(m-1) mod prime を事前計算
let pow_base = fn (m: int) ->
  let rec go = fn i -> fn p ->
    if i >= m - 1 then p
    else go (i + 1) ((p * base) % prime) in
  if m <= 1 then 1 else go 0 1;

// hash を rolling: 古い文字 c_old を引き、 新文字 c_new を足す
let roll = fn (h: int) -> fn (c_old: int) -> fn (c_new: int) -> fn (high: int) ->
  // h = (h - c_old * high) * base + c_new
  let sub = (c_old * high) % prime in
  let stripped = ((h - sub) + prime * 2) % prime in
  (stripped * base + c_new) % prime;

let rabin_search = fn (text: str) -> fn (pat: str) ->
  let n = str_len text in
  let m = str_len pat in
  if m == 0 || m > n then Nil
  else
    let pat_hash = initial_hash pat 0 m in
    let high = pow_base m in
    let h0 = initial_hash text 0 m in
    let rec scan = fn i -> fn h -> fn acc ->
      let matched =
        if h == pat_hash && str_eq_range text i pat 0 m then
          Cons (i, acc)
        else acc in
      if i + m >= n then matched
      else
        let c_old = ord (char_at text i) in
        let c_new = ord (char_at text (i + m)) in
        let h_next = roll h c_old c_new high in
        scan (i + 1) h_next matched in
    let rec rev = fn (xs: int list) -> fn (acc: int list) ->
      match xs with
      | Nil -> acc
      | Cons (h, t) -> rev t (Cons (h, acc)) in
    rev (scan 0 h0 (Nil: int list)) Nil;

let show_list = fn (xs: int list) ->
  let rec go = fn (xs: int list) -> fn first ->
    match xs with
    | Nil -> ""
    | Cons (h, t) ->
      let prefix = if first then "" else ", " in
      prefix ++ show h ++ go t false in
  "[" ++ go xs true ++ "]";

let report = fn (text: str) -> fn (pat: str) ->
  print ("rabin_search \"" ++ text ++ "\" \"" ++ pat ++ "\" = " ++ show_list (rabin_search text pat));

let _ = print "=== Rabin-Karp string search ===";
let _ = report "abracadabra" "abra";          // [0, 7]
let _ = report "aaaaa" "aa";                  // [0, 1, 2, 3]
let _ = report "aabaabaaab" "aabaaab";        // [3]
let _ = report "hello world hello again" "hello";  // [0, 12]
let _ = report "xxxx" "yyyy";                  // []
let _ = report "match exact" "match exact";    // [0]

0
