# Phase 37: GitHub Linguist doesn't recognize `.mere` yet, so highlight
# them as OCaml as a stopgap (both are ML-family with similar surface).
# To be removed once tree-sitter-mere is ready and a Linguist PR has landed.
*.mere linguist-language=OCaml

# scripts/run_wasm.js is a test harness, not generated code
scripts/run_wasm.js linguist-vendored=false

# Line endings
* text=auto eol=lf
*.bat text eol=crlf

# Binary
*.png binary
*.jpg binary
*.wasm binary
